# ───────────────────────────────────────────
#  Скопируй в .env.prod и заполни своими значениями
#  cp .env.prod.example .env.prod
# ───────────────────────────────────────────

# Postgres (внутри docker сети, наружу не выставляется)
POSTGRES_USER=messenger
POSTGRES_PASSWORD=ОЧЕНЬ_ДЛИННЫЙ_СЕКРЕТ_СЮДА
POSTGRES_DB=messenger

# JWT — сгенерируй так:  openssl rand -base64 48
JWT_SECRET=замени-меня-длинной-случайной-строкой

# Публичные URL — куда юзер ходит браузером.
# Без домена это http://<IP_сервера>:<порт>
# ВНИМАНИЕ: PUBLIC_API_URL «вшивается» в frontend на этапе сборки.
# Если сменишь — нужно пересобрать frontend: docker compose -f docker-compose.prod.yml build frontend
PUBLIC_WEB_URL=http://1.2.3.4:3000
PUBLIC_API_URL=http://1.2.3.4:4000

# Порты, которые слушает сам хост (можно поменять, если 3000/4000 заняты)
FRONTEND_PORT=3000
BACKEND_PORT=4000
